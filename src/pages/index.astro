---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHeading from '@components/SectionHeading.astro';
import { getCollection } from 'astro:content';

const techniques = await getCollection('techniques');
const sortedTechniques = techniques.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<BaseLayout
  title="Dr. Jane Doe, LMHC — Individual Therapy"
  description="Licensed mental health counselor offering compassionate, evidence-based individual therapy for adults navigating anxiety, life transitions, and trauma. Telehealth, Florida."
>
  <!-- ───────────────────────────── HERO ─────────────────────────────── -->
  <section class="bg-white pt-20 pb-24 md:pt-28 md:pb-32">
    <div class="max-w-5xl mx-auto px-6">
      <div class="max-w-2xl">
        <p class="text-sage-600 text-sm font-medium tracking-widest uppercase mb-5">
          Individual Therapy · Telehealth · Florida
        </p>
        <h1 class="font-display text-5xl md:text-6xl lg:text-7xl text-stone-900 leading-[1.1] mb-7">
          A space to heal,<br />find clarity,<br />
          <em class="not-italic text-sage-700">and grow.</em>
        </h1>
        <p class="text-stone-600 text-xl leading-relaxed mb-10 max-w-xl">
          I offer compassionate, evidence-based therapy for adults navigating anxiety, life transitions, trauma, and the ordinary difficulty of being human.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact" class="btn-primary">
            Reach out today
          </a>
          <a href="/about" class="btn-secondary">
            Learn about my approach
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─────────────────────── ACCEPTING CLIENTS BANNER ──────────────── -->
  <div class="bg-sage-600 text-white">
    <div class="max-w-5xl mx-auto px-6 py-4 flex items-center gap-3">
      <span class="inline-block w-2 h-2 rounded-full bg-sage-200 flex-shrink-0"></span>
      <p class="text-sm font-medium">
        Currently accepting new clients — <a href="/contact" class="underline underline-offset-2 hover:text-sage-100 transition-colors">schedule a free 15-minute consultation</a>
      </p>
    </div>
  </div>

  <!-- ─────────────────────────────── ABOUT PREVIEW ─────────────────── -->
  <section class="py-20 md:py-28 bg-stone-50">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <!-- Photo placeholder -->
        <div class="order-2 md:order-1">
          <div class="aspect-[4/5] rounded-2xl bg-sage-100 flex items-center justify-center overflow-hidden">
            <div class="text-center p-8">
              <div class="w-24 h-24 rounded-full bg-sage-200 mx-auto mb-4 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-sage-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
              <p class="text-sage-500 text-sm font-medium">Photo coming soon</p>
            </div>
          </div>
        </div>

        <!-- Text -->
        <div class="order-1 md:order-2">
          <SectionHeading eyebrow="About me">
            Helping people find their way through.
          </SectionHeading>
          <p class="text-stone-600 leading-relaxed mb-6">
            I'm a licensed mental health counselor with over a decade of experience working with adults through anxiety, depression, trauma, and the big transitions that life brings — career changes, relationship shifts, grief, and the search for meaning.
          </p>
          <p class="text-stone-600 leading-relaxed mb-8">
            I believe every person carries an innate capacity to heal. My job is to help you find and trust that capacity — through evidence-based methods, genuine curiosity, and a warm, non-judgmental presence.
          </p>
          <a href="/about" class="btn-secondary">
            Read my full bio &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─────────────────────────── TECHNIQUES PREVIEW ────────────────── -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
        <SectionHeading eyebrow="How I work" class="mb-0">
          Evidence-based approaches,<br />tailored to you.
        </SectionHeading>
        <a href="/approach" class="text-sage-700 font-medium text-sm hover:text-sage-800 transition-colors flex-shrink-0">
          See full approach &rarr;
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {sortedTechniques.map((technique) => (
          <div class="bg-stone-50 border border-stone-100 rounded-2xl p-7 hover:border-sage-200 hover:bg-sage-50 transition-colors">
            <h3 class="font-display text-xl text-stone-900 mb-3">{technique.data.title}</h3>
            <p class="text-stone-600 text-sm leading-relaxed">{technique.data.summary}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ────────────────────────────── WHAT TO EXPECT ─────────────────── -->
  <section class="py-20 md:py-28 bg-stone-50">
    <div class="max-w-5xl mx-auto px-6">
      <SectionHeading eyebrow="Getting started">
        What to expect.
      </SectionHeading>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-4">
        {[
          {
            step: '01',
            title: 'Free consultation',
            body: 'We start with a 15-minute phone call — no pressure, no commitment. It\'s a chance for us to meet, for you to ask questions, and to see if we\'re a good fit.',
          },
          {
            step: '02',
            title: 'First session',
            body: 'Your first session is about getting to know you — your history, what\'s bringing you in, and what you\'re hoping for. We\'ll begin to sketch out a path forward together.',
          },
          {
            step: '03',
            title: 'Ongoing work',
            body: 'Most clients meet weekly or bi-weekly. We\'ll revisit goals regularly, adjusting pace and focus as you grow. Therapy ends when you\'re ready, not on a fixed schedule.',
          },
        ].map(({ step, title, body }) => (
          <div>
            <p class="font-display text-4xl text-sage-200 font-semibold mb-4">{step}</p>
            <h3 class="font-display text-xl text-stone-900 mb-3">{title}</h3>
            <p class="text-stone-600 text-sm leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─────────────────────────────── FINAL CTA ─────────────────────── -->
  <section class="bg-sage-900 text-white py-20 md:py-28">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <h2 class="font-display text-3xl md:text-4xl mb-6 leading-tight">
        Ready to take the first step?
      </h2>
      <p class="text-sage-200 text-lg mb-10 max-w-xl mx-auto leading-relaxed">
        Reaching out is often the hardest part. Send a message and I'll respond within one business day.
      </p>
      <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 bg-white text-sage-900 font-semibold rounded-lg hover:bg-sage-50 transition-colors text-base">
        Get in touch
      </a>
    </div>
  </section>
</BaseLayout>
