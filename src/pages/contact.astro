---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHeading from '@components/SectionHeading.astro';
---

<BaseLayout
  title="Contact — Dr. Jane Doe, LMHC"
  description="Reach out to Dr. Jane Doe, LMHC to schedule a free 15-minute consultation or ask a question about starting therapy."
>
  <!-- ─────────────────────────── HEADER ────────────────────────────── -->
  <section class="bg-white pt-16 pb-12 md:pt-20 md:pb-16 border-b border-stone-100">
    <div class="max-w-5xl mx-auto px-6">
      <p class="text-sage-600 text-sm font-medium tracking-widest uppercase mb-4">Contact</p>
      <h1 class="font-display text-4xl md:text-5xl text-stone-900 leading-tight">
        Let's talk.
      </h1>
      <p class="text-stone-600 mt-5 max-w-xl leading-relaxed text-lg">
        Fill out the form below and I'll be in touch within one business day. If you'd prefer, you can also call or email directly.
      </p>
    </div>
  </section>

  <!-- ─────────────────────── CONTACT CONTENT ──────────────────────── -->
  <section class="py-20 bg-stone-50">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-5 gap-12">

        <!-- Sidebar info -->
        <aside class="md:col-span-2 space-y-8">
          <div>
            <SectionHeading>Get in touch.</SectionHeading>
            <div class="space-y-5 mt-2 text-sm text-stone-600">
              <div class="flex gap-4 items-start">
                <div class="w-8 h-8 rounded-lg bg-sage-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-sage-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <p class="font-medium text-stone-900 mb-0.5">Phone</p>
                  <a href="tel:+12395551234" class="text-sage-700 hover:text-sage-800 transition-colors">(239) 555-1234</a>
                </div>
              </div>

              <div class="flex gap-4 items-start">
                <div class="w-8 h-8 rounded-lg bg-sage-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-sage-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <p class="font-medium text-stone-900 mb-0.5">Email</p>
                  <a href="mailto:hello@example.com" class="text-sage-700 hover:text-sage-800 transition-colors">hello@example.com</a>
                </div>
              </div>

              <div class="flex gap-4 items-start">
                <div class="w-8 h-8 rounded-lg bg-sage-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-sage-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <p class="font-medium text-stone-900 mb-0.5">Response time</p>
                  <p>Within one business day</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Privacy notice -->
          <div class="bg-amber-50 border border-amber-200 rounded-xl p-5 text-sm">
            <p class="font-semibold text-amber-900 mb-2">Privacy notice</p>
            <p class="text-amber-800 leading-relaxed">
              This form is <strong>not encrypted</strong> and is not suitable for protected health information (PHI). Please do not share diagnoses, medication details, or other sensitive medical information here.
            </p>
            <p class="text-amber-700 mt-2 text-xs">
              If you need a HIPAA-compliant channel, please call or email directly.
            </p>
          </div>

          <!-- Future scheduling hook -->
          <!--
            FUTURE: Drop in a SimplePractice / Jane App booking widget here.
            e.g.: <a href="https://[practice].clientsecure.me" class="btn-primary w-full text-center mt-4">
                    Book directly online
                  </a>
          -->
        </aside>

        <!-- Contact form -->
        <div class="md:col-span-3">
          <div class="bg-white border border-stone-100 rounded-2xl p-8 shadow-sm">
            <form
              action="https://formspree.io/f/YOUR_FORM_ID"
              method="POST"
              class="space-y-6"
            >
              <!-- Formspree honeypot (spam prevention) -->
              <input type="text" name="_gotcha" class="hidden" aria-hidden="true" tabindex="-1" autocomplete="off" />
              <input type="hidden" name="_subject" value="New client inquiry from website" />
              <input type="hidden" name="_next" value="https://yourdomain.com/thank-you" />

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="first-name" class="form-label">First name <span class="text-stone-400">(required)</span></label>
                  <input
                    id="first-name"
                    type="text"
                    name="first_name"
                    required
                    autocomplete="given-name"
                    placeholder="Jane"
                    class="form-input"
                  />
                </div>
                <div>
                  <label for="last-name" class="form-label">Last name <span class="text-stone-400">(required)</span></label>
                  <input
                    id="last-name"
                    type="text"
                    name="last_name"
                    required
                    autocomplete="family-name"
                    placeholder="Smith"
                    class="form-input"
                  />
                </div>
              </div>

              <div>
                <label for="email" class="form-label">Email address <span class="text-stone-400">(required)</span></label>
                <input
                  id="email"
                  type="email"
                  name="email"
                  required
                  autocomplete="email"
                  placeholder="you@example.com"
                  class="form-input"
                />
              </div>

              <div>
                <label for="phone" class="form-label">Phone number <span class="text-stone-400">(optional)</span></label>
                <input
                  id="phone"
                  type="tel"
                  name="phone"
                  autocomplete="tel"
                  placeholder="(555) 000-0000"
                  class="form-input"
                />
              </div>

              <div>
                <label for="reason" class="form-label">What brings you to therapy? <span class="text-stone-400">(optional)</span></label>
                <select id="reason" name="reason" class="form-select">
                  <option value="" disabled selected>Select one…</option>
                  <option value="anxiety-stress">Anxiety or stress</option>
                  <option value="depression">Depression or low mood</option>
                  <option value="trauma">Trauma or PTSD</option>
                  <option value="relationships">Relationship difficulties</option>
                  <option value="life-transition">Life transition</option>
                  <option value="grief">Grief or loss</option>
                  <option value="other">Other / not sure yet</option>
                </select>
              </div>

              <div>
                <label for="message" class="form-label">Anything else you'd like to share? <span class="text-stone-400">(optional)</span></label>
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  placeholder="Tell me a little about what's going on, or ask any questions you have. No need to share anything sensitive here."
                  class="form-input resize-y min-h-[100px]"
                ></textarea>
                <p class="mt-1.5 text-xs text-stone-400">Do not share protected health information (diagnoses, medications) in this form.</p>
              </div>

              <div>
                <label class="flex gap-3 items-start cursor-pointer">
                  <input
                    type="checkbox"
                    name="privacy_acknowledged"
                    required
                    class="mt-0.5 w-4 h-4 rounded border-stone-300 text-sage-600 focus:ring-sage-500 flex-shrink-0"
                  />
                  <span class="text-sm text-stone-600">
                    I understand this form is not encrypted and I will not include protected health information.
                    <span class="text-stone-400"> (required)</span>
                  </span>
                </label>
              </div>

              <button type="submit" class="btn-primary w-full">
                Send message
              </button>
            </form>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
